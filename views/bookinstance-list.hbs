<h1>{{title}}</h1>
{{#if bookInstanceList}}
  <ul>
    {{#each bookInstanceList}} 
      <li>
        <a href="{{url}}">{{book.title}} : {{imprint}}</a>
        {{#ifEquals status "Available"}}
          <span class="text-success">
            {{../status}}
          </span>
        {{/ifEquals}}
        {{#ifEquals status "Maintenance"}}
          <span class="text-danger">
            {{../status}}
          </span>
        {{/ifEquals}}
        {{#ifEquals status "Loaned"}}
          <span class="text-warning">Loaned</span>
          <span>(Due: {{../due_back}})</span>
        {{/ifEquals}}
        {{#ifEquals status "Reserved"}}
          <span class="text-warning">
            {{../status}}
          </span>
          </span>
        {{/ifEquals}}
      </li>
    {{/each}}
  </ul>
{{else}}
  <p>There are no book copies in the library</p>
{{/if}}
